# Async PostgreSQL URL (psycopg async)
DATABASE_URL=postgresql+psycopg_async://archai:archai@localhost:5432/archai

# Comma-separated browser origins (no trailing slashes)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# development | production (production hides OpenAPI UIs)
ENV=development

# Logging
LOG_LEVEL=INFO

# SQL echo (verbose; dev only)
SQL_ECHO=false

# Firebase Admin (pick one): full service account JSON string — best for Cloud Run / secrets
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}
FIREBASE_CREDENTIALS_JSON=
# Or path to the downloaded JSON file (local dev)
FIREBASE_CREDENTIALS_PATH=

# Check token revocation on each verify (extra latency / Firebase quota)
FIREBASE_CHECK_REVOKED=false

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR
# Amounts in smallest currency unit (paise for INR)
RAZORPAY_PRO_AMOUNT_PAISE=99900
RAZORPAY_LIFETIME_AMOUNT_PAISE=499900
RAZORPAY_PRO_VALIDITY_DAYS=365

# Graph evaluation LLM: stub | openai
EVALUATION_LLM_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_EVAL_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EVAL_TIMEOUT_S=120

# Interview: tail window of chat messages sent to the model
INTERVIEW_MAX_MESSAGES=40

# Free plan: AI calls per UTC month (evaluate, each interview start/respond, simulate incident)
FREE_AI_CALLS_MONTHLY_LIMIT=20
