# Optional: full API origin for local dev when not using Vite proxy.
# Leave empty to use same-origin /api (Docker nginx or Vite proxy).
VITE_API_URL=

# Vite dev server proxy target for /api → backend
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Firebase Web SDK (required for graphs, evaluate, interview, etc.)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
